{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-design-rules.dev/schema/common.schema.json",
  "title": "AI Design Rules Common Metadata",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(OBS|RESEARCH|RULE|PAT|PROMPT|SKILL|REVIEW|CHECK|REF)-[0-9]{5}$"
    },
    "alias": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "object_type": {
      "type": "string",
      "enum": [
        "observation",
        "research",
        "rule",
        "pattern",
        "prompt",
        "skill",
        "review",
        "checklist",
        "reference_project"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "superseded"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "maturity": {
      "type": "string",
      "enum": [
        "seed",
        "validated",
        "canonical"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "product_type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "surface": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "does_not_apply_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "title",
    "object_type",
    "status",
    "version",
    "category",
    "relationships"
  ],
  "$defs": {
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "derived_from",
            "cites",
            "inspired_by",
            "requires",
            "validates",
            "implements",
            "related_to",
            "supersedes",
            "deprecated_by",
            "replaced_by"
          ]
        },
        "target": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "target"
      ]
    }
  }
}
