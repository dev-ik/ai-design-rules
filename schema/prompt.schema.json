{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-design-rules.dev/schema/prompt.schema.json",
  "title": "Prompt",
  "allOf": [
    {
      "$ref": "./common.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "id": {
          "pattern": "^PROMPT-[0-9]{5}$"
        },
        "object_type": {
          "const": "prompt"
        }
      }
    }
  ]
}
